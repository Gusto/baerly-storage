# Claude Things
.claude/reviews/
.claude/research/
.claude/worktrees/
.claude/settings.local.json

# Dependencies
node_modules/
.pnpm-store/
.pnpm-debug.log*

# Build output
dist/
build/
*.tsbuildinfo

# pnpm pack output (see ticket 04 / staged tarball install path)
*.tgz

# Test & coverage
coverage/
*.lcov
.nyc_output/

# Bench harness outputs (per-run JSON + CSV)
bench/results/*
!bench/results/.gitkeep
!bench/results/load/
bench/results/load/*
!bench/results/load/.gitkeep

# Bench load-harness fixtures (raw corpora; only calibration.json
# under presets/ is checked in — see scripts/fetch-bench-fixtures.sh).
bench/fixtures/

# Vite / Vitest / Rolldown caches
.vite/
.vitest/
.rolldown/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment & secrets
.env
.env.*
!.env.example
.dev.vars
!.dev.vars.example
credentials/

# Per-example local dev artifacts. The example dirs themselves
# ship `_gitignore` (template form that survives `npm pack`) rather
# than a working `.gitignore`, so these patterns live at the repo
# root to keep `pnpm dev` inside `examples/*` from staging secrets
# or framework state.
.wrangler/
.baerly-data/

# Editor & IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Project-specific
docs/whisper/

# Day-one gate temp scaffolds
.baerly-day-one/
