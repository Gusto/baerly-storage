{
  "name": "baerly-storage",
  "version": "0.1.0",
  "description": "Vendorless document database that runs over any S3-compatible storage API.",
  "keywords": [
    "cloudflare-workers",
    "database",
    "document-database",
    "edge",
    "http-api",
    "nosql",
    "r2",
    "s3",
    "s3-compatible",
    "self-hosted",
    "serverless",
    "typescript"
  ],
  "license": "MIT",
  "bin": {
    "baerly": "./dist/baerly.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js"
    },
    "./http": {
      "types": "./dist/http.d.ts",
      "import": "./dist/http.js"
    },
    "./cloudflare": {
      "types": "./dist/cloudflare.d.ts",
      "import": "./dist/cloudflare.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./maintenance": {
      "types": "./dist/maintenance.d.ts",
      "import": "./dist/maintenance.js"
    },
    "./observability": {
      "types": "./dist/observability.d.ts",
      "import": "./dist/observability.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./client/react": {
      "types": "./dist/client-react.d.ts",
      "import": "./dist/client-react.js"
    },
    "./client/testing": {
      "types": "./dist/client-testing.d.ts",
      "import": "./dist/client-testing.js"
    },
    "./dev": {
      "types": "./dist/dev.d.ts",
      "import": "./dist/dev.js"
    },
    "./dev/vite": {
      "types": "./dist/dev-vite.d.ts",
      "import": "./dist/dev-vite.js"
    },
    "./export": {
      "types": "./dist/export.d.ts",
      "import": "./dist/export.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "pretest": "pnpm run build",
    "test": "vitest run --project=default",
    "test:coverage": "vitest run --project=default --coverage",
    "test:minio": "MINIO=1 vitest run --project=default",
    "test:conformance": "CONFORMANCE=1 MINIO=1 vitest run --project=default tests/integration/conformance.test.ts",
    "test:export-smoke": "EXPORT_SMOKE=1 vitest run --project=default tests/integration/export-smoke.test.ts",
    "test:export-round-trip": "vitest run --project=default tests/integration/export-round-trip.test.ts",
    "build": "rolldown -c && pnpm -r --filter \"./packages/*\" build",
    "baerly": "node dist/baerly.js",
    "prepare": "lefthook install && pnpm run build",
    "format": "oxfmt tests packages",
    "format:check": "oxfmt --check tests packages",
    "lint": "oxlint tests packages",
    "test:randomize": "FC_NUM_RUNS=10000 vitest run --project=default",
    "test:fuzz-phase5": "FC_NUM_RUNS=10000 vitest run --project=default tests/integration/phase5-crash-fuzz.test.ts",
    "test:adapter-cloudflare": "ADAPTER_CLOUDFLARE=1 vitest run --project=cloudflare-pool",
    "test:http-conformance": "vitest run --project=default tests/integration/http-conformance.test.ts",
    "test:adapter-node": "MINIO=1 vitest run --project=default packages/adapter-node",
    "test:adapters": "pnpm test:adapter-cloudflare && pnpm test:adapter-node",
    "test:manual-e2e": "vitest run --project=default manual-e2e/cloudflare/e2e.test.ts manual-e2e/node/e2e.test.ts",
    "gate:day-one": "vitest run --project=default tests/integration/day-one-handshake.test.ts",
    "verify": "pnpm run typecheck && pnpm run lint",
    "dev:storage": "docker compose up -d --wait",
    "dev:storage:stop": "docker compose down",
    "eval:check": "node eval/check-acceptance.mjs",
    "eval:run": "node eval/run.mjs",
    "eval:score": "node eval/score.mjs",
    "bench:r2": "node --import ./bench/register-hooks.mjs bench/r2-contention.ts",
    "bench:r2:matrix": "node --import ./bench/register-hooks.mjs bench/r2-contention-matrix.ts",
    "bench:r2:interpret": "node --import ./bench/register-hooks.mjs bench/r2-contention-interpret.ts",
    "bench:load": "node --import ./bench/register-hooks.mjs bench/load-harness/cli.ts",
    "bench:load:minio": "MINIO=1 node --import ./bench/register-hooks.mjs bench/load-harness/cli.ts --variant=node-minio",
    "bench:load:matrix": "node --import ./bench/register-hooks.mjs bench/load-harness/matrix.ts"
  },
  "dependencies": {
    "@logtape/logtape": "2.0.7"
  },
  "devDependencies": {
    "@baerly/adapter-cloudflare": "workspace:*",
    "@baerly/adapter-node": "workspace:*",
    "@baerly/client": "workspace:*",
    "@baerly/dev": "workspace:*",
    "@baerly/export": "workspace:*",
    "@baerly/protocol": "workspace:*",
    "@baerly/server": "workspace:*",
    "@cloudflare/vitest-pool-workers": "0.16.3",
    "@cloudflare/workers-types": "^4",
    "@fast-check/vitest": "^0.4.1",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^25.6.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260508.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@xmldom/xmldom": "^0.9.10",
    "aws4fetch": "1.0.20",
    "execa": "^9.5.2",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.7.0",
    "happy-dom": "^20.9.0",
    "idb-keyval": "^6.2.2",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rolldown": "^1.0.0",
    "rolldown-plugin-dts": "^0.25.0",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "^4",
    "@xmldom/xmldom": "^0.9.10",
    "aws4fetch": "^1.0.20",
    "react": "^18 || ^19",
    "vite": "^5 || ^6 || ^7 || ^8"
  },
  "peerDependenciesMeta": {
    "@cloudflare/workers-types": {
      "optional": true
    },
    "@xmldom/xmldom": {
      "optional": true
    },
    "aws4fetch": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.1.2"
}
