{
  "name": "@gusto/baerly-storage",
  "version": "0.4.1",
  "description": "Document database for S3 and Cloudflare R2 that runs in your request handler — tiny, LLM-friendly TypeScript API, no database server",
  "keywords": [
    "append-only-log",
    "aws-s3",
    "cloudflare-workers",
    "content-addressable-storage",
    "document-database",
    "edge-computing",
    "http-api",
    "minio",
    "multi-tenant",
    "nosql",
    "object-storage",
    "r2",
    "s3",
    "s3-compatible",
    "serverless",
    "typescript"
  ],
  "homepage": "https://github.com/Gusto/baerly-storage#readme",
  "bugs": {
    "url": "https://github.com/Gusto/baerly-storage/issues"
  },
  "license": "Apache-2.0",
  "author": "Eric Baer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gusto/baerly-storage.git"
  },
  "bin": {
    "baerly": "dist/baerly.js"
  },
  "files": [
    "dist",
    "NOTICE"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./packages/server/src/index.ts",
      "import": "./packages/server/src/index.ts"
    },
    "./auth": {
      "types": "./packages/server/src/auth/index.ts",
      "import": "./packages/server/src/auth/index.ts"
    },
    "./http": {
      "types": "./packages/server/src/http/index.ts",
      "import": "./packages/server/src/http/index.ts"
    },
    "./cloudflare": {
      "types": "./packages/adapter-cloudflare/src/index.ts",
      "import": "./packages/adapter-cloudflare/src/index.ts"
    },
    "./node": {
      "types": "./packages/adapter-node/src/index.ts",
      "import": "./packages/adapter-node/src/index.ts"
    },
    "./s3": {
      "types": "./packages/adapter-node/src/s3.ts",
      "import": "./packages/adapter-node/src/s3.ts"
    },
    "./maintenance": {
      "types": "./packages/server/src/maintenance.ts",
      "import": "./packages/server/src/maintenance.ts"
    },
    "./observability": {
      "types": "./packages/server/src/observability/index.ts",
      "import": "./packages/server/src/observability/index.ts"
    },
    "./config": {
      "types": "./packages/protocol/src/app-config.ts",
      "import": "./packages/protocol/src/app-config.ts"
    },
    "./client": {
      "types": "./packages/client/src/index.ts",
      "import": "./packages/client/src/index.ts"
    },
    "./client/react": {
      "types": "./packages/client/src/react/index.ts",
      "import": "./packages/client/src/react/index.ts"
    },
    "./dev": {
      "types": "./packages/dev/src/index.ts",
      "import": "./packages/dev/src/index.ts"
    },
    "./dev/vite": {
      "types": "./packages/dev/src/vite-plugin.ts",
      "import": "./packages/dev/src/vite-plugin.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./auth": {
        "types": "./dist/auth.d.ts",
        "import": "./dist/auth.js"
      },
      "./http": {
        "types": "./dist/http.d.ts",
        "import": "./dist/http.js"
      },
      "./cloudflare": {
        "types": "./dist/cloudflare.d.ts",
        "import": "./dist/cloudflare.js"
      },
      "./node": {
        "types": "./dist/node.d.ts",
        "import": "./dist/node.js"
      },
      "./s3": {
        "types": "./dist/s3.d.ts",
        "import": "./dist/s3.js"
      },
      "./maintenance": {
        "types": "./dist/maintenance.d.ts",
        "import": "./dist/maintenance.js"
      },
      "./observability": {
        "types": "./dist/observability.d.ts",
        "import": "./dist/observability.js"
      },
      "./config": {
        "types": "./dist/app-config.d.ts",
        "import": "./dist/app-config.js"
      },
      "./client": {
        "types": "./dist/client.d.ts",
        "import": "./dist/client.js"
      },
      "./client/react": {
        "types": "./dist/client-react.d.ts",
        "import": "./dist/client-react.js"
      },
      "./dev": {
        "types": "./dist/dev.d.ts",
        "import": "./dist/dev.js"
      },
      "./dev/vite": {
        "types": "./dist/dev-vite.d.ts",
        "import": "./dist/dev-vite.js"
      }
    },
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "pretest": "node scripts/build-if-needed.mjs",
    "test": "vitest run --project=default",
    "test:agent": "vitest run --project=default --reporter=minimal --silent=passed-only",
    "test:one": "pnpm run build && vitest run --project=default",
    "test:coverage": "vitest run --project=default --coverage",
    "test:minio": "MINIO=1 vitest run --project=default",
    "test:conformance": "CONFORMANCE=1 MINIO=1 vitest run --project=default tests/integration/conformance.test.ts",
    "test:export-smoke": "EXPORT_SMOKE=1 vitest run --project=default tests/integration/export-smoke.test.ts",
    "test:export-round-trip": "vitest run --project=default tests/integration/export-round-trip.test.ts",
    "build": "rolldown -c && pnpm -r --filter \"./packages/*\" build && node scripts/merge-third-party-licenses.mjs",
    "baerly": "node dist/baerly.js",
    "release": "node scripts/publish.mjs",
    "changeset": "changeset",
    "changeset:version": "changeset version && node scripts/gen-spec.ts && rm -f packages/create-baerly-storage/CHANGELOG.md",
    "prepare": "node scripts/prepare.mjs",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint tests packages",
    "test:randomize": "FC_NUM_RUNS=10000 vitest run --project=default",
    "test:fuzz-maintenance": "FC_NUM_RUNS=10000 vitest run --project=default tests/integration/maintenance-crash-fuzz.test.ts",
    "test:adapter-cloudflare": "ADAPTER_CLOUDFLARE=1 vitest run --project=cloudflare-pool",
    "test:http-conformance": "vitest run --project=default tests/integration/http-conformance.test.ts",
    "test:adapter-node": "MINIO=1 vitest run --project=default packages/adapter-node",
    "test:adapters": "pnpm test:adapter-cloudflare && pnpm test:adapter-node",
    "test:parity": "vitest run --project=default packages/protocol/src/storage/memory.test.ts packages/dev/src/local-fs.test.ts packages/adapter-node/src/s3-http.conformance.test.ts tests/integration/collection-api.test.ts tests/integration/randomized.test.ts",
    "test:manual-e2e": "vitest run --project=default manual-e2e/cloudflare/e2e.test.ts manual-e2e/node/e2e.test.ts",
    "test:mutate": "stryker run",
    "mutate:survivors": "node scripts/mutation-survivors.mjs",
    "test:coverage:protocol": "vitest run --config stryker.vitest.config.ts --coverage --coverage.provider=v8 --coverage.include='packages/protocol/src/**/*.ts' --coverage.exclude='**/*.test.ts' --coverage.exclude='**/*.test-d.ts' --coverage.exclude='**/index.ts'",
    "gate:day-one": "vitest run --project=default tests/integration/day-one-handshake.test.ts",
    "gen:spec": "node scripts/gen-spec.ts",
    "gen:version-matrix": "node scripts/check-version-matrix.ts --write",
    "bundle-sizes": "node scripts/bundle-sizes.mjs",
    "check:exports": "node scripts/check-exports.mjs",
    "check:publint": "node scripts/check-publint.mjs",
    "verify:package": "node scripts/build-if-needed.mjs && BAERLY_SKIP_BUILD=1 pnpm run check:exports && BAERLY_SKIP_BUILD=1 pnpm run check:publint",
    "verify:rest": "pnpm run verify:examples && pnpm run format:check && node scripts/add-ts-extensions.mjs --check && node scripts/lint-use-query.mjs && node scripts/lint-package-layers.mjs && node scripts/lint-format-coverage.mjs && node scripts/check-spec-drift.ts && node scripts/check-version-matrix.ts",
    "verify:code": "pnpm run typecheck && pnpm run lint && pnpm run verify:rest",
    "verify": "pnpm run verify:code && pnpm run verify:docs",
    "verify:agent": "tsgo --noEmit --pretty false && oxlint --format=unix --quiet tests packages && pnpm run verify:rest && pnpm run verify:docs",
    "verify:spec": "node scripts/check-spec-drift.ts",
    "verify:version-matrix": "node scripts/check-version-matrix.ts",
    "verify:docs": "node scripts/verify-docs.mjs && node scripts/verify-docs-taxonomy.mjs && remark . --quiet --frail --no-stdout && node scripts/verify-mermaid.mjs",
    "verify:doc-taxonomy": "node scripts/verify-docs-taxonomy.mjs",
    "verify:doc-links": "remark . --quiet --frail --no-stdout",
    "verify:mermaid": "node scripts/verify-mermaid.mjs",
    "verify:examples": "pnpm --filter minimal-cloudflare typecheck && pnpm --filter minimal-node typecheck && pnpm --filter react-cloudflare typecheck && pnpm --filter react-node typecheck",
    "dev:storage": "docker compose up -d --wait",
    "dev:storage:stop": "docker compose down",
    "worktree:bootstrap": "node scripts/worktree-bootstrap.mjs",
    "bench:r2": "node --import ./bench/register-hooks.mjs bench/r2-contention.ts",
    "bench:r2:matrix": "node --import ./bench/register-hooks.mjs bench/r2-contention-matrix.ts",
    "bench:r2:interpret": "node --import ./bench/register-hooks.mjs bench/r2-contention-interpret.ts",
    "bench:load": "node --import ./bench/register-hooks.mjs bench/load-harness/cli.ts",
    "bench:load:minio": "MINIO=1 node --import ./bench/register-hooks.mjs bench/load-harness/cli.ts --variant=node-minio",
    "bench:load:matrix": "node --import ./bench/register-hooks.mjs bench/load-harness/matrix.ts",
    "bench:lsn-reverse-walk": "node --import ./bench/register-hooks.mjs bench/lsn-reverse-walk.ts",
    "bench:fold-cost": "node --import ./bench/register-hooks.mjs bench/fold-cost.ts",
    "bench:maintenance-backlog": "node --import ./bench/register-hooks.mjs bench/maintenance-backlog.ts",
    "bench:amortized-write-cost": "node --import ./bench/register-hooks.mjs bench/amortized-write-cost.ts",
    "bench:write-amp-stress": "node --import ./bench/register-hooks.mjs bench/write-amp-stress.ts",
    "bench:collection-fanout": "node --import ./bench/register-hooks.mjs bench/collection-fanout.ts"
  },
  "dependencies": {
    "@logtape/logtape": "2.2.2"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@baerly/adapter-cloudflare": "workspace:*",
    "@baerly/adapter-node": "workspace:*",
    "@baerly/client": "workspace:*",
    "@baerly/dev": "workspace:*",
    "@baerly/protocol": "workspace:*",
    "@baerly/server": "workspace:*",
    "@changesets/cli": "^2.31.0",
    "@cloudflare/vitest-pool-workers": "0.16.14",
    "@cloudflare/workers-types": "^4.20260630.1",
    "@fast-check/vitest": "^0.4.1",
    "@hono/node-server": "^2.0.6",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260610.1",
    "@vitest/coverage-v8": "^4.1.8",
    "ajv": "^8.20.0",
    "aws4fetch": "1.0.20",
    "esbuild": "^0.28.1",
    "execa": "^9.6.1",
    "fast-check": "^4.8.0",
    "happy-dom": "^20.10.6",
    "lefthook": "^2.1.9",
    "mermaid": "^11.15.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "pg": "^8.21.0",
    "publint": "^0.3.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remark-cli": "^12.0.1",
    "remark-gfm": "^4.0.1",
    "remark-validate-links": "^13.1.0",
    "rolldown": "^1.1.0",
    "rolldown-plugin-dts": "^0.25.2",
    "rollup-license-plugin": "3.2.1",
    "vite": "^8.1.2",
    "vitest": "^4.1.9",
    "yaml": "2.9.0"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "^4",
    "react": "^18 || ^19",
    "vite": "^5 || ^6 || ^7 || ^8"
  },
  "peerDependenciesMeta": {
    "@cloudflare/workers-types": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.1.2"
}
