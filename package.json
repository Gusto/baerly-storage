{
    "name": "mps3",
    "description": "Provide clientside multiplayer and optimistic updates over any s3-compatible storage API",
    "version": "0.0.81",
    "license": "MIT",
    "author": {
        "name": "Tom Larkworthy"
    },
    "main": "dist/mps3.js",
    "type": "module",
    "packageManager": "pnpm@10.31.0",
    "scripts": {
        "test": "vitest run",
        "doc": "typedoc --plugin typedoc-plugin-markdown",
        "build": "pnpm run doc; rolldown -c",
        "prepare": "pnpm run build",
        "format": "oxfmt src",
        "lint": "oxlint src",
        "test:randomize": "while pnpm test; [ $? -ne 1 ] ; do :; done"
    },
    "devDependencies": {
        "@aws-sdk/client-s3": "3.370.0",
        "@types/jsdom": "^21.1.2",
        "@types/json-merge-patch": "^0.0.8",
        "@types/node": "^22.9.0",
        "@xmldom/xmldom": "^0.8.10",
        "aws4fetch": "1.0.17",
        "fake-indexeddb": "^4.0.2",
        "idb-keyval": "^6.2.1",
        "oxfmt": "^0.48.0",
        "oxlint": "^1.63.0",
        "rolldown": "^1.0.0-beta.20",
        "typedoc": "^0.25.0",
        "typedoc-plugin-markdown": "^3.16.0",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^2.1.8"
    },
    "files": [
        "dist"
    ],
    "prettier": {
        "tabWidth": 4
    }
}
