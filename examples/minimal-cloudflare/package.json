{
  "name": "minimal-cloudflare",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "typecheck": "tsc -b --noEmit",
    "verify": "pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@gusto/baerly-storage": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.39.0",
    "@cloudflare/workers-types": "^4",
    "@types/node": "^24.0.0",
    "happy-dom": "^20.10.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wrangler": "^4.95.0"
  },
  "packageManager": "pnpm@11.1.2"
}
