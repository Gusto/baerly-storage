{
  "name": "minimal-node",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "baerly dev",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "start": "node --experimental-strip-types src/server/index.ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -b --noEmit",
    "verify": "pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.10",
    "aws4fetch": "^1.0.20",
    "baerly-storage": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@11.1.2"
}
