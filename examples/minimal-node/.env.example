# Storage credentials (AWS S3 default; R2 when R2_ACCOUNT_ID is set).
# For Minio / GCS, edit `src/server/index.ts` to use the matching
# factory from `baerly-storage/node` (`minioStorage` / `gcsStorage`).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BUCKET=
# Set to your Cloudflare R2 account ID (left half of the
# https://<account>.r2.cloudflarestorage.com endpoint) to switch
# storage from AWS S3 to R2. Leave unset for AWS S3.
# R2_ACCOUNT_ID=

# Auth — choose ONE
# Production: JWKS-backed JWT.
# JWKS_URL=https://login.example.com/.well-known/jwks.json
# JWT_ISSUER=https://login.example.com/
# JWT_AUDIENCE=https://api.example.com/
# Development: shared secret.
SHARED_SECRET=

# Maintenance — optional. Comma-separated list of collection slugs;
# each tick runs one compact+GC pass per (TENANT, collection) pair.
# Leave unset to skip the in-process maintenance loop (operators can
# wire an external scheduler — a PaaS cron, a k8s CronJob, a systemd
# timer — instead).
# MAINTENANCE_COLLECTIONS=tickets,comments

# Static assets — directory served by baerlyNode({ webRoot }).
# Default `dist/client` matches `vite build`'s output. Override when
# shipping a pre-built bundle into a different directory.
# WEB_ROOT=dist/client

# Server
PORT=8080
TENANT=minimal-demo

# Observability — Phase-9 canonical log lines emitted on stdout.
# LOG_LEVEL: debug | info (default) | warn | error
LOG_LEVEL=info
# LOG_SAMPLE: fraction of successful requests sampled (0.0 - 1.0).
# Errors are always kept; maintenance runs always emit.
LOG_SAMPLE=0.1
