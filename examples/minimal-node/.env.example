# Storage selection. Defaults to local filesystem storage
# (./.baerly-data, zero credentials) for local dev. A deployment
# (NODE_ENV=production or a known PaaS) requires a bucket below — the
# server fails loud rather than running on local-fs, which is local-dev
# only. Self-hosting without a cloud bucket? Run MinIO on the box, or use
# SQLite + Litestream.
# MinIO is for local conformance. Other S3-compatible endpoints require
# `baerly doctor --bucket` plus owner validation; GCS S3-interop is not
# supported for database use today.
# AWS S3: set BUCKET + AWS creds (AWS_REGION optional).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BUCKET=
# Set to your Cloudflare R2 account ID (left half of the
# https://<account>.r2.cloudflarestorage.com endpoint) to use R2
# instead of AWS S3 (still set BUCKET + AWS_* creds). Leave unset for S3.
# R2_ACCOUNT_ID=

# Server
PORT=8080
