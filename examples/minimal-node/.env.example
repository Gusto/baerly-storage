# Storage credentials (AWS S3 default; R2 when R2_ACCOUNT_ID is set).
# MinIO is for local conformance. Other S3-compatible endpoints require
# `baerly doctor --bucket` plus owner validation; GCS S3-interop is not
# supported for database use today.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BUCKET=
# Set to your Cloudflare R2 account ID (left half of the
# https://<account>.r2.cloudflarestorage.com endpoint) to switch
# storage from AWS S3 to R2. Leave unset for AWS S3.
# R2_ACCOUNT_ID=

# Server
PORT=8080
