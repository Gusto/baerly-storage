# Copy to `.dev.vars` (gitignored) for `pnpm dev` to read locally
# (`@cloudflare/vite-plugin` loads it into the in-process Worker).
# In production, set each value via:
#
#     wrangler secret put <NAME>
#
# The Worker's `src/server/index.ts` chooses which verifier to use
# based on which of these is set; pick one branch per environment.

# --- SHARED_SECRET (single-tenant dev) -------------------------
# Used by both the server (verifier) AND the Vite dev-auth plugin
# (which injects Authorization: Bearer <SHARED_SECRET> on /v1/*
# requests in dev). The SPA bundle never ships this value — the
# plugin runs server-side and `apply: "serve"` skips production
# builds entirely.
#
# `dev-shared-secret` is a working default so `cp .dev.vars.example
# .dev.vars && pnpm dev` works out of the box. Replace with a
# strong random value (e.g. `openssl rand -hex 32`) for any
# environment reachable from the public internet.
SHARED_SECRET=dev-shared-secret

# CF Access identifiers (`CF_ACCESS_TEAM_DOMAIN`,
# `CF_ACCESS_AUDIENCE_TAG`) are public, not secrets — declare them
# in `wrangler.jsonc:vars` instead of here. `baerly doctor` reads
# them from `wrangler.jsonc:vars` only.
