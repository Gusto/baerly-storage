{
  "name": "react-cloudflare",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "typecheck": "tsc -b --noEmit",
    "verify": "pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@gusto/baerly-storage": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.39.0",
    "@cloudflare/workers-types": "^4",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "happy-dom": "^20.9.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "wrangler": "^4.95.0"
  },
  "packageManager": "pnpm@11.1.2"
}
