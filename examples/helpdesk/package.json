{
  "name": "helpdesk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm -F @helpdesk/server seed",
    "dev": "pnpm -F \"@helpdesk/*\" --parallel dev",
    "build": "pnpm -F \"@helpdesk/*\" build",
    "seed": "pnpm -F @helpdesk/server seed",
    "reset": "rm -rf .baerly-data",
    "test": "vitest run smoke.test.ts"
  },
  "devDependencies": {
    "@baerly/adapter-node": "workspace:*",
    "@baerly/client": "workspace:*",
    "@baerly/dev": "workspace:*",
    "@baerly/protocol": "workspace:*",
    "@baerly/server": "workspace:*",
    "vitest": "^4.1.5"
  }
}
