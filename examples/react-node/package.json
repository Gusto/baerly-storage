{
  "name": "react-node",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "start": "node --experimental-strip-types src/server/index.ts",
    "test": "vitest run",
    "typecheck": "tsc -b --noEmit",
    "verify": "pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@gusto/baerly-storage": "workspace:*",
    "aws4fetch": "1.0.20",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "happy-dom": "^20.10.6",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.1.2"
}
