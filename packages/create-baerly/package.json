{
  "name": "create-baerly",
  "version": "0.1.0",
  "description": "Scaffold a new baerly app. Run via `npm create baerly@latest -- my-app --target=cloudflare` (post-publish; today, stage via `pnpm pack` — see ticket 04).",
  "license": "MIT",
  "bin": {
    "create-baerly": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./config": {
      "types": "./src/config.ts",
      "import": "./src/config.ts"
    }
  },
  "scripts": {
    "build": "rolldown -c",
    "prepack": "rolldown -c"
  },
  "dependencies": {
    "@baerly/server": "workspace:*",
    "@clack/prompts": "^0.7.0",
    "citty": "^0.1.6",
    "picocolors": "^1.1.1"
  }
}
