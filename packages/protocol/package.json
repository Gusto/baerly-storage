{
    "name": "@baerly/protocol",
    "version": "0.0.0",
    "description": "Pure protocol primitives — types, errors, JSON merge-patch, constants, hashing, ordered maps. No I/O.",
    "license": "MIT",
    "type": "module",
    "private": true,
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./src/index.ts"
        }
    },
    "publishConfig": {
        "exports": {
            ".": {
                "types": "./dist/index.d.ts",
                "import": "./dist/index.js"
            }
        }
    }
}
