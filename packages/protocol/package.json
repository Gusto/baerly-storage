{
  "name": "@baerly/protocol",
  "version": "0.1.0",
  "private": true,
  "description": "Pure protocol primitives — types, errors, JSON merge-patch, constants, hashing, ordered maps. No I/O.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./conformance": {
      "types": "./src/storage/conformance.ts",
      "import": "./src/storage/conformance.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./conformance": {
        "types": "./dist/conformance.d.ts",
        "import": "./dist/conformance.js"
      }
    }
  }
}
