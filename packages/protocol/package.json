{
  "name": "@baerly/protocol",
  "version": "0.1.0",
  "private": true,
  "description": "Workspace-internal protocol kernel. Bundled into @gusto/baerly-storage (private) and baerly-storage (public). Not a separately published package.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./conformance": {
      "types": "./src/storage/conformance.ts",
      "import": "./src/storage/conformance.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./conformance": {
        "types": "./dist/conformance.d.ts",
        "import": "./dist/conformance.js"
      }
    }
  }
}
