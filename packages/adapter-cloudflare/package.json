{
  "name": "@baerly/adapter-cloudflare",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Workers adapter — R2 binding fast-path Storage + fetch(req, env, ctx) mount.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./worker": {
      "types": "./src/worker.ts",
      "import": "./src/worker.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./worker": {
        "types": "./dist/worker.d.ts",
        "import": "./dist/worker.js"
      }
    }
  },
  "dependencies": {
    "@baerly/dev": "workspace:*",
    "@baerly/protocol": "workspace:*",
    "@baerly/server": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260715.1"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "^4 || ^5"
  },
  "peerDependenciesMeta": {
    "@cloudflare/workers-types": {
      "optional": true
    }
  }
}
