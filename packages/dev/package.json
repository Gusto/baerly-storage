{
  "name": "@baerly/dev",
  "version": "0.1.0",
  "private": true,
  "description": "Dev harness — LocalFsStorage adapter, ensureTable helper, and terminal-UX utilities for dev servers.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./local-fs": {
      "types": "./src/local-fs.ts",
      "import": "./src/local-fs.ts"
    },
    "./vite": {
      "types": "./src/vite-plugin.ts",
      "import": "./src/vite-plugin.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "dependencies": {
    "@baerly/adapter-node": "workspace:*",
    "@baerly/protocol": "workspace:*",
    "@baerly/server": "workspace:*",
    "@hono/node-server": "^2.0.6",
    "picocolors": "^1.1.1"
  },
  "peerDependencies": {
    "vite": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  }
}
