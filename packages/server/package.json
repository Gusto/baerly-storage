{
  "name": "@baerly/server",
  "version": "0.0.0",
  "private": true,
  "description": "Baerly server — portable HTTP/RPC surface over a Storage adapter. Phase 3 ships `Db` + `_raw` Storage escape hatch; HTTP routing lands in Phase 6.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./auth": {
      "types": "./src/auth/index.ts",
      "import": "./src/auth/index.ts"
    },
    "./http": {
      "types": "./src/http/index.ts",
      "import": "./src/http/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./auth": {
        "types": "./dist/auth.d.ts",
        "import": "./dist/auth.js"
      },
      "./http": {
        "types": "./dist/http.d.ts",
        "import": "./dist/http.js"
      }
    }
  },
  "dependencies": {
    "@baerly/protocol": "workspace:*",
    "hono": "^4.12.18"
  }
}
