{
  "$schema": "https://baerly.dev/spec/ir-schema.json",
  "specVersion": "1",
  "kernelVersion": "0.3.0",
  "errorCodes": [
    {
      "code": "InvalidConfig",
      "httpStatus": 400,
      "retriable": false,
      "summary": "Caller config or input is invalid."
    },
    {
      "code": "NetworkError",
      "httpStatus": 502,
      "retriable": true,
      "summary": "S3/HTTP transport failure (5xx, retries exhausted)."
    },
    {
      "code": "AccessDenied",
      "httpStatus": 403,
      "retriable": false,
      "summary": "S3 returned 403 — credentials or bucket policy."
    },
    {
      "code": "InvalidResponse",
      "httpStatus": 502,
      "retriable": false,
      "summary": "Server returned unparseable data."
    },
    {
      "code": "Internal",
      "httpStatus": 500,
      "retriable": false,
      "summary": "Internal invariant violation — file a bug."
    },
    {
      "code": "SchemaError",
      "httpStatus": 400,
      "retriable": false,
      "summary": "Document body failed schema validation; carries .issues."
    },
    {
      "code": "Conflict",
      "httpStatus": 409,
      "retriable": true,
      "summary": "Write conflicted (CAS exhausted, duplicate _id, guarded key)."
    },
    {
      "code": "Unauthorized",
      "httpStatus": 401,
      "retriable": false,
      "summary": "Verifier returned no identity."
    },
    {
      "code": "NotFound",
      "httpStatus": 404,
      "retriable": false,
      "summary": "Addressed resource does not exist."
    },
    {
      "code": "PayloadTooLarge",
      "httpStatus": 413,
      "retriable": false,
      "summary": "Request body exceeded MAX_BODY_BYTES."
    },
    {
      "code": "UnsatisfiablePredicate",
      "httpStatus": 400,
      "retriable": false,
      "summary": "Predicate is well-formed but contradicts itself."
    },
    {
      "code": "UseQueryAwaitedRecorder",
      "httpStatus": null,
      "retriable": false,
      "summary": "A useQuery callback awaited a recorder terminal."
    },
    {
      "code": "UnexpectedWriteInQuery",
      "httpStatus": null,
      "retriable": false,
      "summary": "A write verb was called inside a useQuery callback."
    },
    {
      "code": "MutationFailed",
      "httpStatus": null,
      "retriable": false,
      "summary": "A useMutation callback rejected with a non-BaerlyError."
    }
  ],
  "operators": [
    {
      "name": "eq",
      "valueType": "equality",
      "summary": "Strict equality."
    },
    {
      "name": "gt",
      "valueType": "range",
      "summary": "Greater-than; bound is string or finite number."
    },
    {
      "name": "gte",
      "valueType": "range",
      "summary": "Greater-or-equal; bound is string or finite number."
    },
    {
      "name": "lt",
      "valueType": "range",
      "summary": "Less-than; bound is string or finite number."
    },
    {
      "name": "lte",
      "valueType": "range",
      "summary": "Less-or-equal; bound is string or finite number."
    },
    {
      "name": "in",
      "valueType": "set",
      "summary": "Set membership; empty array → UnsatisfiablePredicate."
    }
  ],
  "collectionMethods": [
    {
      "name": "first",
      "params": "",
      "returns": "Promise<T | undefined>"
    },
    {
      "name": "all",
      "params": "",
      "returns": "Promise<T[]>"
    },
    {
      "name": "count",
      "params": "",
      "returns": "Promise<number>"
    },
    {
      "name": "get",
      "params": "id: string",
      "returns": "Promise<T | undefined>"
    },
    {
      "name": "where",
      "params": "predicate: PredicateArg<T>",
      "returns": "Query<T>"
    },
    {
      "name": "order",
      "params": "spec: OrderSpec<T>",
      "returns": "Query<T>"
    },
    {
      "name": "limit",
      "params": "n: number",
      "returns": "Query<T>"
    },
    {
      "name": "insert",
      "params": "doc: Partial<T> & DocumentData",
      "returns": "Promise<{ _id: string }>",
      "throws": ["SchemaError", "Conflict"]
    },
    {
      "name": "update",
      "params": "id: string, patch: Partial<T>",
      "returns": "Promise<{ modified: number }>",
      "throws": ["SchemaError", "Conflict"]
    },
    {
      "name": "replace",
      "params": "id: string, doc: T",
      "returns": "Promise<void>",
      "throws": ["SchemaError", "Conflict", "NotFound"]
    },
    {
      "name": "delete",
      "params": "id: string",
      "returns": "Promise<{ deleted: number }>",
      "throws": ["Conflict"]
    }
  ],
  "queryMethods": [
    {
      "name": "where",
      "params": "predicate: PredicateArg<T>",
      "returns": "Query<T>"
    },
    {
      "name": "order",
      "params": "spec: OrderSpec<T>",
      "returns": "Query<T>"
    },
    {
      "name": "limit",
      "params": "n: number",
      "returns": "Query<T>"
    },
    {
      "name": "first",
      "params": "",
      "returns": "Promise<T | undefined>"
    },
    {
      "name": "all",
      "params": "",
      "returns": "Promise<T[]>"
    },
    {
      "name": "count",
      "params": "",
      "returns": "Promise<number>"
    },
    {
      "name": "update",
      "params": "patch: Partial<T>",
      "returns": "Promise<{ modified: number }>",
      "throws": ["SchemaError", "Conflict"]
    },
    {
      "name": "delete",
      "params": "",
      "returns": "Promise<{ deleted: number }>",
      "throws": ["Conflict"]
    }
  ],
  "storageInterface": [
    {
      "name": "get",
      "params": "key: string, opts?: StorageGetOptions",
      "returns": "Promise<StorageGetResult | null>"
    },
    {
      "name": "put",
      "params": "key: string, body: Uint8Array, opts?: StoragePutOptions",
      "returns": "Promise<StoragePutResult>"
    },
    {
      "name": "delete",
      "params": "key: string, opts?: { signal?: AbortSignal }",
      "returns": "Promise<void>"
    },
    {
      "name": "list",
      "params": "prefix: string, opts?: { startAfter?: string; maxKeys?: number; signal?: AbortSignal }",
      "returns": "AsyncIterable<StorageListEntry>"
    }
  ],
  "predicateWire": {
    "clause": {
      "op": "PredicateOpName",
      "field": "string (top-level key or dotted path)",
      "value": "DocumentValue | DocumentValue[] (array iff op==='in')"
    },
    "envelope": {
      "clauses": "PredicateClause[] (AND across clauses; empty → match-all)"
    }
  },
  "schemaContract": {
    "adapter": "StandardSchemaV1",
    "validatesPostImage": true,
    "idRequired": true,
    "rejectsWith": "SchemaError"
  },
  "httpRoutes": [
    {
      "method": "GET",
      "path": "/v1/healthz",
      "auth": "anonymous",
      "summary": "Liveness probe."
    },
    {
      "method": "GET",
      "path": "/v1/spec",
      "auth": "anonymous",
      "summary": "Machine-readable contract; tenant collections only when authed."
    },
    {
      "method": "GET",
      "path": "/v1/c/:collection",
      "auth": "verified",
      "summary": "Read/query a collection (?where=, ?order=, ?limit=)."
    },
    {
      "method": "GET",
      "path": "/v1/c/:collection/:id",
      "auth": "verified",
      "summary": "Read one document by id (404 when absent)."
    },
    {
      "method": "POST",
      "path": "/v1/c/:collection",
      "auth": "verified",
      "summary": "Insert a document."
    },
    {
      "method": "PATCH",
      "path": "/v1/c/:collection/:id",
      "auth": "verified",
      "summary": "Merge-patch a document by id (body { patch })."
    },
    {
      "method": "PUT",
      "path": "/v1/c/:collection/:id",
      "auth": "verified",
      "summary": "Replace a document by id (body { doc })."
    },
    {
      "method": "DELETE",
      "path": "/v1/c/:collection/:id",
      "auth": "verified",
      "summary": "Delete a document by id (204; 404 when absent)."
    },
    {
      "method": "GET",
      "path": "/v1/count",
      "auth": "verified",
      "summary": "Count matching rows."
    },
    {
      "method": "GET",
      "path": "/v1/since",
      "auth": "verified",
      "summary": "Long-poll the collection log tail."
    }
  ]
}
