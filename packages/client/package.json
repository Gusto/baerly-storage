{
  "name": "@baerly/client",
  "version": "0.1.0",
  "private": true,
  "description": "Baerly typed HTTP client — fetchers + `useLiveQuery` / `useLiveDocument` live-read hooks.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./react": {
      "types": "./src/react/index.ts",
      "import": "./src/react/index.ts"
    },
    "./testing": {
      "types": "./src/testing/index.ts",
      "import": "./src/testing/index.ts"
    }
  },
  "dependencies": {
    "@baerly/protocol": "workspace:*"
  },
  "peerDependencies": {
    "@baerly/server": "workspace:*",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "@baerly/server": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  }
}
