{
  "name": "@baerly/adapter-node",
  "version": "0.1.0",
  "private": true,
  "description": "Node adapter — re-exports S3HttpStorage + LocalFsStorage and exposes a node:http RequestListener that wraps Db + ServerWriter.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "dependencies": {
    "@baerly/dev": "workspace:*",
    "@baerly/protocol": "workspace:*",
    "@baerly/server": "workspace:*"
  }
}
