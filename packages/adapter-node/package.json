{
  "name": "@baerly/adapter-node",
  "version": "0.1.0",
  "private": true,
  "description": "Node adapter — re-exports S3HttpStorage and exposes a node:http RequestListener that wraps Db + Writer.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "dependencies": {
    "@baerly/dev": "workspace:*",
    "@baerly/protocol": "workspace:*",
    "@baerly/server": "workspace:*",
    "@hono/node-server": "^2.0.4",
    "aws4fetch": "1.0.20",
    "fast-xml-parser": "^5.3.0",
    "hono": "^4.12.23",
    "picocolors": "^1.1.1"
  }
}
