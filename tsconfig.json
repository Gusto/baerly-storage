{
  "compilerOptions": {
    "target": "ES2025",
    "lib": ["ES2025", "ESNext.TypedArrays", "DOM", "DOM.Iterable"],
    "module": "preserve",

    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "resolveJsonModule": true,
    "erasableSyntaxOnly": true,
    "allowImportingTsExtensions": true,

    // exactOptionalPropertyTypes is deliberately not enabled — it conflicts
    // with the LLM-zero-shot option-bag ergonomics in docs/about/thesis.md
    // (an LLM writing `{ inFanoutThreshold: undefined }` to mean "leave
    // default" would type-error).
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noPropertyAccessFromIndexSignature": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "noEmit": true,
    "declaration": true,
    "sourceMap": true,

    "jsx": "react-jsx",

    "skipLibCheck": true,
    "types": ["node", "@cloudflare/workers-types"]
  },
  "include": [
    "tests",
    "packages/*/src",
    "manual-e2e/**/*.ts",
    "*.config.ts",
    "scripts/**/*.ts",
    "bench/**/*",
    "examples/helpdesk/src/**/*.ts",
    "examples/helpdesk/src/**/*.tsx",
    "examples/helpdesk/src/**/*.d.ts",
    "examples/helpdesk/vite.config.ts",
    "examples/*/apps/*/src/**/*.ts",
    "examples/*/apps/*/src/**/*.tsx",
    "examples/*/apps/*/src/**/*.d.ts",
    "examples/*/apps/*/*.config.ts",
    "examples/*/types.ts",
    "examples/*/smoke.test.ts"
  ],
  "exclude": ["tests/integration/conformance.test.ts", "tests/fixtures/check-acceptance"]
}
