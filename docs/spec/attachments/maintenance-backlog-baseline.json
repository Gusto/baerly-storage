{
  "schema_version": 1,
  "bench": "maintenance-backlog",
  "description": "Backlog (live tail entries + object count + snapshot-over-ceiling) vs write rate, per maintenance trigger (in-band write-tick / scheduled cron) and profile (cf-free / node). Measures whether FREE-RATE maintenance keeps up within the ~30 writes/min M-size envelope. Measures only.",
  "seed": 12239110,
  "sim_minutes": 30,
  "working_set": 50,
  "body_bytes": 2000,
  "min_entries_to_compact": 50,
  "rate_grid": [10, 30, 60, 120],
  "methodology": {
    "simulated_time": "writes/min is the knob; a 'minute' is a unit mapping to `rate` real Db writes — NO wall-clock claim (the bench runs in seconds)",
    "gc_grace": "gcGraceMillis/graceMillis = 0 so a marked orphan sweeps the same pass — models the drain CEILING (sweep throughput vs orphan production p), not the 7-day-delayed production timing",
    "in_band": "every commit ticks runBoundedMaintenance at the profile (production write-tick default), phasesPerTick=both",
    "scheduled": "in-band disabled; one runScheduledMaintenance tick per simulated minute, alternating compact (even) / GC (odd) — the CF even/odd-minute cron pattern",
    "verdict": "bounded = last-third mean live-tail not > 1.5x first-third mean (converged); growing = climbs past that and by more than one fold slice"
  },
  "invariants": {
    "maintenance_target_ratio": 1,
    "maintenance_min_live_bytes": 65536,
    "gc_starvation_guard": 4,
    "cf_free_drain_ratio": "gcMaxSweeps/gcInterval = 10/4 = 2.5 (>= orphan-production p keeps object count bounded — graduation.md §7.1)",
    "node_drain_ratio": "gcMaxSweeps/gcInterval = 100/2 = 50"
  },
